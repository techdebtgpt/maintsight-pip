# MaintSight CLI Environment Configuration
# Copy this file to .env and modify the values as needed

# CLI Database Integration (Optional)
# Set this to connect CLI to a MaintSight server for enhanced features
MAINTSIGHT_API_URL=http://localhost:8000
MAINTSIGHT_API_KEY=optional-api-key

# Model Configuration (Local CLI)
MODEL_PATH=models/xgboost_model.pkl
METADATA_PATH=models/xgboost_model_metadata.json

# CLI Output Configuration
DEFAULT_OUTPUT_DIR=.maintsight
OPEN_BROWSER_ON_COMPLETION=true
VERBOSE_OUTPUT=false

# CLI Performance
MAX_WORKERS=4
CACHE_ENABLED=true
CACHE_DIR=.maintsight/cache

# Logging (CLI)
LOG_LEVEL=INFO
CLI_LOG_FILE=.maintsight/cli.log

# Git Configuration
DEFAULT_BRANCH=main
WINDOW_SIZE_DAYS=150
ONLY_EXISTING_FILES=true

# HTML Report Configuration
HTML_THEME=default
AUTO_REFRESH_INTERVAL=30`
ENABLE_EDITING=true